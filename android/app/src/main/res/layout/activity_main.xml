<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.18"
        android:paddingStart="20dp"
        android:paddingEnd="8dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_theme" />

    <ImageButton
        android:id="@+id/btn_theme"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_palette"
        android:contentDescription="@string/cd_theme"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Current track card -->
    <LinearLayout
        android:id="@+id/card_current"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_current_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="15sp"
            android:textColor="#E8E8E8"
            android:singleLine="true"
            android:ellipsize="middle" />

        <TextView
            android:id="@+id/tv_current_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.06"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hint_no_track"
            android:textSize="11sp"
            android:textColor="#666666"
            android:layout_marginTop="6dp"
            android:visibility="visible" />
    </LinearLayout>

    <!-- Waveform card -->
    <LinearLayout
        android:id="@+id/card_waveform"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/card_current"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.darthmotzkus.pcmplayer.WaveformView
            android:id="@+id/waveform"
            android:layout_width="match_parent"
            android:layout_height="120dp" />

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0:00 / 0:00"
            android:textSize="14sp"
            android:textColor="#FAC775"
            android:fontFamily="monospace"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <!-- Controls card -->
    <LinearLayout
        android:id="@+id/card_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/card_waveform"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Transport row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_prev"
                style="@style/TransportBtn"
                android:src="@drawable/ic_prev"
                android:contentDescription="@string/cd_prev" />

            <ImageButton
                android:id="@+id/btn_stop"
                style="@style/TransportBtn"
                android:src="@drawable/ic_stop"
                android:contentDescription="@string/cd_stop" />

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_marginHorizontal="6dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_play"
                android:contentDescription="@string/cd_play_pause" />

            <ImageButton
                android:id="@+id/btn_next"
                style="@style/TransportBtn"
                android:src="@drawable/ic_next"
                android:contentDescription="@string/cd_next" />

            <ImageButton
                android:id="@+id/btn_repeat"
                style="@style/TransportBtn"
                android:src="@drawable/ic_repeat_off"
                android:contentDescription="@string/cd_repeat" />
        </LinearLayout>

        <!-- Speed row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/speed_label"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.18"
                android:layout_marginEnd="12dp" />

            <ImageButton
                android:id="@+id/btn_speed_down"
                style="@style/MiniBtn"
                android:src="@drawable/ic_minus"
                android:contentDescription="@string/cd_speed_down" />

            <TextView
                android:id="@+id/tv_speed"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:text="1.00x"
                android:textSize="13sp"
                android:textColor="#FAC775"
                android:gravity="center"
                android:fontFamily="monospace" />

            <ImageButton
                android:id="@+id/btn_speed_up"
                style="@style/MiniBtn"
                android:src="@drawable/ic_plus"
                android:contentDescription="@string/cd_speed_up" />
        </LinearLayout>
    </LinearLayout>

    <!-- Playlist card -->
    <LinearLayout
        android:id="@+id/card_playlist"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/card_controls"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/playlist_label"
                android:textColor="#888888"
                android:textSize="10sp"
                android:letterSpacing="0.28" />

            <ImageButton
                android:id="@+id/btn_open"
                style="@style/MiniBtn"
                android:src="@drawable/ic_add"
                android:contentDescription="@string/cd_add_files" />

            <ImageButton
                android:id="@+id/btn_clear_playlist"
                style="@style/MiniBtn"
                android:src="@drawable/ic_clear"
                android:contentDescription="@string/cd_clear" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_playlist"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
